# =============================================================================
# Origami — Autonomous Content Creation Agent
# Copy this file to .env and fill in real values. Never commit .env to git.
# =============================================================================

# Anthropic — LLM brain (model: claude-sonnet-4-20250514)
ANTHROPIC_API_KEY=sk-ant-placeholder-replace-me

# Supabase — Auth + database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Telegram — Approval bot + daily digests
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNOpqRSTuvwXYZ
TELEGRAM_DEFAULT_CHAT_ID=your-telegram-chat-id

# Platform credentials
# YouTube Data API v3
YOUTUBE_CLIENT_ID=your-youtube-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret

# Instagram Graph API (requires FB Business account)
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
META_ACCESS_TOKEN=your-meta-long-lived-access-token

# X (Twitter) via OpenTweet API ($5.99/mo)
OPENTWEET_API_KEY=your-opentweet-api-key

# Trend research sources
# Reddit API (PRAW)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret

# NewsAPI (optional — free tier covers MVP)
NEWSAPI_KEY=your-newsapi-key-optional

# Apify — for X trend scraping (pay-per-event)
APIFY_API_TOKEN=your-apify-api-token

# Media generation
# Pollinations.ai — free without key, key unlocks higher rate limits
POLLINATIONS_API_KEY=your-pollinations-api-key-optional

# Replicate — fallback image gen if Pollinations rate-limits (~$0.04/img)
REPLICATE_API_TOKEN=your-replicate-api-token

# Cloudflare R2 — media storage (10GB free, no egress fees)
CLOUDFLARE_R2_ACCESS_KEY=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_BUCKET=origami-media
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# n8n — dashboard → orchestrator communication
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.onrender.com
N8N_API_KEY=your-n8n-api-key
